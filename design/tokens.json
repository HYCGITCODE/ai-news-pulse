{
  "version": "1.0.0",
  "lastUpdated": "2026-03-08",
  "theme": "Minimalist Modern",
  "references": ["Linear", "Stripe", "Apple"],
  
  "colors": {
    "light": {
      "background": {
        "primary": "#FFFFFF",
        "secondary": "#F9FAFB",
        "tertiary": "#F3F4F6"
      },
      "foreground": {
        "primary": "#111827",
        "secondary": "#6B7280",
        "tertiary": "#9CA3AF"
      },
      "border": {
        "default": "#E5E7EB",
        "hover": "#D1D5DB",
        "focus": "#3B82F6"
      },
      "accent": {
        "primary": "#3B82F6",
        "hover": "#2563EB",
        "active": "#1D4ED8"
      },
      "semantic": {
        "success": "#10B981",
        "warning": "#F59E0B",
        "error": "#EF4444",
        "info": "#3B82F6"
      }
    },
    "dark": {
      "background": {
        "primary": "#111827",
        "secondary": "#1F2937",
        "tertiary": "#374151"
      },
      "foreground": {
        "primary": "#F9FAFB",
        "secondary": "#9CA3AF",
        "tertiary": "#6B7280"
      },
      "border": {
        "default": "#374151",
        "hover": "#4B5563",
        "focus": "#60A5FA"
      },
      "accent": {
        "primary": "#60A5FA",
        "hover": "#93C5FD",
        "active": "#BFDBFE"
      },
      "semantic": {
        "success": "#34D399",
        "warning": "#FBBF24",
        "error": "#F87171",
        "info": "#60A5FA"
      }
    }
  },

  "typography": {
    "fontFamily": {
      "sans": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif",
      "mono": "SF Mono, Monaco, Consolas, 'Liberation Mono', monospace"
    },
    "fontSize": {
      "xs": "12px",
      "sm": "14px",
      "base": "16px",
      "lg": "18px",
      "xl": "20px",
      "2xl": "24px",
      "3xl": "30px"
    },
    "fontWeight": {
      "normal": "400",
      "medium": "500",
      "semibold": "600",
      "bold": "700"
    },
    "lineHeight": {
      "tight": "1.25",
      "normal": "1.5",
      "relaxed": "1.75"
    },
    "letterSpacing": {
      "tight": "-0.025em",
      "normal": "0",
      "wide": "0.025em"
    }
  },

  "spacing": {
    "unit": "4px",
    "scale": {
      "0": "0px",
      "1": "4px",
      "2": "8px",
      "3": "12px",
      "4": "16px",
      "5": "20px",
      "6": "24px",
      "8": "32px",
      "10": "40px",
      "12": "48px",
      "16": "64px"
    }
  },

  "borderRadius": {
    "none": "0px",
    "sm": "4px",
    "base": "6px",
    "md": "8px",
    "lg": "12px",
    "xl": "16px",
    "full": "9999px"
  },

  "shadows": {
    "none": "none",
    "sm": "0 1px 2px 0 rgba(0, 0, 0, 0.05)",
    "base": "0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px -1px rgba(0, 0, 0, 0.1)",
    "md": "0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -2px rgba(0, 0, 0, 0.1)",
    "lg": "0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.1)"
  },

  "breakpoints": {
    "mobile": "375px",
    "tablet": "768px",
    "desktop": "1024px",
    "wide": "1920px"
  },

  "transitions": {
    "fast": "150ms ease",
    "normal": "200ms ease",
    "slow": "300ms ease"
  },

  "componentStates": {
    "newsCard": {
      "default": {
        "background": "background.primary",
        "border": "border.default",
        "shadow": "sm"
      },
      "hover": {
        "background": "background.secondary",
        "border": "border.hover",
        "shadow": "md",
        "transform": "translateY(-2px)"
      },
      "active": {
        "background": "background.tertiary",
        "border": "accent.primary"
      },
      "loading": {
        "opacity": "0.6",
        "pointerEvents": "none"
      }
    },
    "sourceTag": {
      "default": {
        "background": "background.secondary",
        "color": "foreground.secondary",
        "border": "border.default"
      },
      "hover": {
        "background": "accent.primary",
        "color": "#FFFFFF",
        "border": "accent.primary"
      },
      "active": {
        "background": "accent.primary",
        "color": "#FFFFFF"
      },
      "disabled": {
        "opacity": "0.5",
        "pointerEvents": "none"
      }
    },
    "button": {
      "default": {
        "background": "accent.primary",
        "color": "#FFFFFF"
      },
      "hover": {
        "background": "accent.hover"
      },
      "active": {
        "background": "accent.active"
      },
      "disabled": {
        "background": "border.default",
        "color": "foreground.tertiary",
        "cursor": "not-allowed"
      }
    }
  },

  "visualAcceptanceCriteria": {
    "pixelTolerance": "2px",
    "colorContrast": {
      "normal": "4.5:1",
      "large": "3:1"
    },
    "tapTarget": {
      "minimum": "44px"
    },
    "fontMinimum": {
      "mobile": "14px",
      "desktop": "12px"
    },
    "loadingState": {
      "skeletonAnimation": "pulse 1.5s infinite",
      "maxWaitTime": "3000ms"
    }
  }
}
